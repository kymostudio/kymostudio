flowchart TB
  classDef customClazz fill:#bbf,stroke:#f66,stroke-width:2px,color:#fff,stroke-dasharray: 5 5
  n0 --> n00@{ shape: text, label: 'new text shape' }
  n00:::customClazz
  n1 --> n11@{ shape: card, label: 'new card shape' }
  n11:::customClazz
  n2 --> n22@{ shape: lin-rect, label: 'new lin-rect shape' }
  n22:::customClazz
  n3 --> n33@{ shape: diamond, label: 'new diamond shape' }
  n33:::customClazz
  n4 --> n44@{ shape: hexagon, label: 'new hexagon shape' }
  n44:::customClazz
