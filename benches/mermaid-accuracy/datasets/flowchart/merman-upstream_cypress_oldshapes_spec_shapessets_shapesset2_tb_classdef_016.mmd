flowchart TB
  classDef customClazz fill:#bbf,stroke:#f66,stroke-width:2px,color:#fff,stroke-dasharray: 5 5
  n0 --> n00@{ shape: rounded, label: 'new rounded shape' }
  n00:::customClazz
  n1 --> n11@{ shape: rect, label: 'new rect shape' }
  n11:::customClazz
  n2 --> n22@{ shape: start, label: 'new start shape' }
  n22:::customClazz
  n3 --> n33@{ shape: stop, label: 'new stop shape' }
  n33:::customClazz
