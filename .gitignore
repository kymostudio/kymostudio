out/
tmp/
dist/
*.egg-info/
node_modules/
# transient screenshots from validation runs
samples/_*.jpeg
samples/_*.png
# Playwright (engine E2E)
test-results/
playwright-report/
.last-run.json
dist-core/
packages/rust/kymo-mermaid/target/
# Cloudflare wrangler build/cache
.wrangler/
