<?xml version="1.0" encoding="UTF-8"?>
<xmi:XMI xmi:version="2.5.1" xmlns:xmi="http://www.omg.org/spec/XMI/20131001" xmlns:uml="http://www.omg.org/spec/UML/20161101">
  <uml:Model xmi:id="model-1" name="SequenceModel">
    <packagedElement xmi:type="uml:Interaction" xmi:id="interaction-1" name="Sequence">
      <lifeline xmi:type="uml:Lifeline" xmi:id="lifeline-1" name="A"/>
      <lifeline xmi:type="uml:Lifeline" xmi:id="lifeline-2" name="B"/>
      <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="occ-5" covered="lifeline-1" message="message-4"/>
      <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="occ-6" covered="lifeline-2" message="message-4"/>
      <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="occ-9" covered="lifeline-2" message="message-8"/>
      <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="occ-10" covered="lifeline-1" message="message-8"/>
      <message xmi:type="uml:Message" xmi:id="message-4" name="SYN" messageSort="synchCall" sendEvent="occ-5" receiveEvent="occ-6"/>
      <message xmi:type="uml:Message" xmi:id="message-8" name="SYN-ACK" messageSort="reply" sendEvent="occ-9" receiveEvent="occ-10"/>
      <ownedComment xmi:type="uml:Comment" xmi:id="comment-3" body="handshake begins" annotatedElement="lifeline-1 lifeline-2"/>
      <ownedComment xmi:type="uml:Comment" xmi:id="comment-7" body="B is now listening" annotatedElement="lifeline-2"/>
      <ownedComment xmi:type="uml:Comment" xmi:id="comment-11" body="connection established" annotatedElement="lifeline-1"/>
    </packagedElement>
  </uml:Model>
</xmi:XMI>
