{
  "name": "@kymostudio/website",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "kymostudio website (kymo.studio) — React landing page + client-side diagram playground at /app/. Built by build.sh into dist/, deployed to Cloudflare Pages (kymo-studio).",
  "license": "Apache-2.0",
  "scripts": {
