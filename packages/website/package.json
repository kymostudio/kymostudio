    "test:e2e": "npm --prefix app run test:e2e"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0"
  },
  "engines": { "node": ">=18" }
}
