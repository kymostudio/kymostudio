{
  "name": "kymostudio",
  "version": "0.3.3",
  "description": "Type it. See it appear. Watch it animate.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "rain1024",
  "keywords": [
    "diagram",
    "diagram-as-code",
    "svg",
    "architecture",
    "icons"
  ],
  "homepage": "https://github.com/kymostudio/kymostudio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kymostudio/kymostudio.git",
    "directory": "packages/js"
  },
  "bugs": {
    "url": "https://github.com/kymostudio/kymostudio/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "kymo-icons": "bin/kymo-icons.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./icons-manifest.json": "./icons-manifest.json"
  },
  "scripts": {
    "sync-icons": "node scripts/sync-icons.mjs",
    "build-manifest": "npm --prefix ../icons run build-manifest",
    "prebuild": "npm run sync-icons",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "pretest": "npm run sync-icons",
    "prepack": "npm run sync-icons && npm run build",
    "test": "npm run build && node --test"
  },
  "files": [
    "dist/",
    "bin/",
    "sets/",
    "icons-manifest.json",
    "icons-collections.json"
  ],
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.9.1",
    "eslint": "^9.0.0",
    "jsdom": "^25.0.1",
    "mxgraph": "^4.2.2",
    "pako": "^2.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0"
  }
}
