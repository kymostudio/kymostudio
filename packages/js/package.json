{
  "name": "kymostudio",
  "version": "0.2.4",
  "description": "Diagram-as-code: turn a declarative .diagram DSL — or a standard BPMN 2.0 .bpmn file — into animated SVG / WebP.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "rain1024",
  "keywords": [
    "diagram",
    "diagram-as-code",
    "svg",
    "architecture",
    "icons"
  ],
  "homepage": "https://github.com/kymostudio/kymostudio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kymostudio/kymostudio.git",
    "directory": "packages/js"
  },
  "bugs": {
    "url": "https://github.com/kymostudio/kymostudio/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./icons-manifest.json": "./icons-manifest.json"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "build-manifest": "node scripts/build-manifest.mjs",
    "prepack": "npm run build",
    "test": "npm run build && node --test"
  },
  "files": [
    "dist/",
    "icons-manifest.json"
  ],
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.9.1",
    "eslint": "^9.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0"
  }
}
