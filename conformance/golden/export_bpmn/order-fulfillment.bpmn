<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="defs_kymo">
  <bpmn:process id="Process_kymo" isExecutable="false">
    <bpmn:startEvent id="Start" name="Order received" />
    <bpmn:task id="Validate" name="Validate order" />
    <bpmn:exclusiveGateway id="InStock" name="In stock?" default="flow3" />
    <bpmn:task id="Notify" name="Notify customer" />
    <bpmn:endEvent id="Cancelled" name="Order cancelled">
      <bpmn:terminateEventDefinition />
    </bpmn:endEvent>
    <bpmn:task id="Payment" name="Process payment" />
    <bpmn:parallelGateway id="Split" name="Split" />
    <bpmn:task id="Pack" name="Pack items" />
    <bpmn:task id="Invoice" name="Generate invoice" />
    <bpmn:parallelGateway id="Sync" name="Sync" />
    <bpmn:task id="Ship" name="Ship order" />
    <bpmn:endEvent id="Delivered" name="Order delivered" />
    <bpmn:sequenceFlow id="flow0" sourceRef="Start" targetRef="Validate" />
    <bpmn:sequenceFlow id="flow1" sourceRef="Validate" targetRef="InStock" />
    <bpmn:sequenceFlow id="flow2" sourceRef="InStock" targetRef="Payment" name="Yes" />
    <bpmn:sequenceFlow id="flow3" sourceRef="InStock" targetRef="Notify" name="No" />
    <bpmn:sequenceFlow id="flow4" sourceRef="Notify" targetRef="Cancelled" />
    <bpmn:sequenceFlow id="flow5" sourceRef="Payment" targetRef="Split" />
    <bpmn:sequenceFlow id="flow6" sourceRef="Split" targetRef="Pack" />
    <bpmn:sequenceFlow id="flow7" sourceRef="Split" targetRef="Invoice" />
    <bpmn:sequenceFlow id="flow8" sourceRef="Pack" targetRef="Sync" />
    <bpmn:sequenceFlow id="flow9" sourceRef="Invoice" targetRef="Sync" />
    <bpmn:sequenceFlow id="flow10" sourceRef="Sync" targetRef="Ship" />
    <bpmn:sequenceFlow id="flow11" sourceRef="Ship" targetRef="Delivered" />
  </bpmn:process>
  <bpmndi:BPMNDiagram>
    <bpmndi:BPMNPlane bpmnElement="Process_kymo">
      <bpmndi:BPMNShape bpmnElement="Start">
