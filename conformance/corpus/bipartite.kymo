# Bipartite layout: two vertical columns side by side, every node on the
# left fully connected to every node on the right. Stress-tests fan-out
# from BOTH `a` and `b` AND fan-in stagger at `c`, `d`, `e`.
a hex/hex-agent/green
b hex/hex-agent/green
c hex/hex-agent/green
d hex/hex-agent/green
e hex/hex-agent/green

layout { { a , b } | { c , d , e } }

a --> c
a --> d
a --> e
b --> c
b --> d
b --> e
